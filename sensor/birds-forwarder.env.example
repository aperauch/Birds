# Copy to /etc/birds-forwarder.env and fill in. Keep this file 0600 root:root.
# The systemd unit loads it via EnvironmentFile.

# Required ----------------------------------------------------------------
INGEST_URL=https://birds.aperauch.com/ingest
INGEST_TOKEN=replace-with-the-secret-you-set-via-wrangler

# Optional ----------------------------------------------------------------
# Path to the BirdNET-Pi SQLite database (default shown).
BIRDNETPI_DB=/home/birdnet/BirdNET-Pi/scripts/birds.db
# Root of BirdNET-Pi audio extractions (default shown).
EXTRACTED_DIR=/home/birdnet/BirdSongs/Extracted
# Identifier if you ever run more than one sensor.
SENSOR_ID=default
# Seconds between database polls.
POLL_INTERVAL=10
# Extra client-side confidence floor (0..1). 0.0 = trust BirdNET-Pi's own filter.
MIN_CONFIDENCE=0.0
# Generate a spectrogram PNG with sox when one isn't already present.
MAKE_SPECTROGRAM=1
# Pin coordinates (otherwise taken from the BirdNET-Pi DB row).
# LAT=00.0000
# LON=00.0000
